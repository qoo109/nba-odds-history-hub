{
  "schemaVersion": "nba-market-taxonomy-v1",
  "createdAt": "2026-07-21",
  "normalizationPolicy": {
    "sourceMarketKeyPreserved": true,
    "sourcePeriodPreserved": true,
    "unknownMarketBehavior": "quarantine_unclassified",
    "automaticSemanticGuessingAllowed": false,
    "openingClosingInferenceAllowed": false
  },
  "eventTypes": [
    {"eventType":"game","canonicalEventRequired":true,"scheduledTipoffRequired":true},
    {"eventType":"futures","canonicalEventRequired":false,"scheduledTipoffRequired":false}
  ],
  "periods": [
    {"periodClass":"full_game","displayName":"Full Game","sourceCodeRequired":true},
    {"periodClass":"first_half","displayName":"First Half","sourceCodeRequired":true},
    {"periodClass":"second_half","displayName":"Second Half","sourceCodeRequired":true},
    {"periodClass":"quarter_1","displayName":"First Quarter","sourceCodeRequired":true},
    {"periodClass":"quarter_2","displayName":"Second Quarter","sourceCodeRequired":true},
    {"periodClass":"quarter_3","displayName":"Third Quarter","sourceCodeRequired":true},
    {"periodClass":"quarter_4","displayName":"Fourth Quarter","sourceCodeRequired":true}
  ],
  "markets": [
    {
      "marketClass":"game_moneyline_full_game",
